ScreenManager:
    MenuScreen:
    ExercisesScreen:
    WorkoutsScreen:
    NewWorkoutScreen:
    ExercisePickerScreen:

<MenuScreen>:
    name: 'menu'
    BoxLayout:
        orientation: 'vertical'
        padding: 40
        spacing: 15
        Label:
            text: 'Трекер тренировок'
        Button:
            text: 'Мои тренировки'
            on_press: root.manager.current='workouts'
            size_hint_y: 0.3
        Button:
            text: 'Редактор упражнений'
            on_press: root.manager.current = 'exercises'
            size_hint_y: 0.1


<ExercisePickerScreen>:
    name: 'exercise_picker'
    BoxLayout:
        orientation: 'vertical'
        padding: 40
        spacing: 15
        Label:
            text: 'Выберите упражнение'
            size_hint_y: 0.1
        BoxLayout:
            size_hint_y: 0.1
            spacing: 5
            TextInput:
                id: exercise_name
                hint_text: 'Новое упражнение'
            Button:
                text: '+'
                size_hint_x: 0.2
                on_press: root.save_exercise(exercise_name.text)
        ScrollView:
            BoxLayout:
                id: picker_list
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 5
        Button:
            text: 'Назад'
            size_hint_y: 0.1
            on_press: root.manager.current = 'new_workout'


<ExercisesScreen>:
    name: 'exercises'
    BoxLayout:
        orientation: 'vertical'
        padding: 40
        spacing: 15
        Label:
            text: 'Упражнения'
            size_hint_y: 0.1
        BoxLayout:
            size_hint_y: 0.1
            spacing: 5
            TextInput:
                id: exercise_name
                hint_text: 'Новое упражнение'
            Button:
                text: '+'
                size_hint_x: 0.25
                on_press: root.save_exercise(exercise_name.text)
        ScrollView:
            id: scroll
            BoxLayout:
                id: exercise_list
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 10
        Button:
            text: 'Назад'
            size_hint_y: 0.115
            on_press: root.manager.current = 'menu'


<WorkoutsScreen>:
    name: 'workouts'
    BoxLayout:
        orientation: 'vertical'
        padding: 40
        spacing: 15
        Label:
            text: 'Мои тренировки'
            size_hint_y: 0.1
        ScrollView:
            BoxLayout:
                id: workout_list
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 10
        Button:
            text: 'Новая тренировка'
            size_hint_y: 0.1
            on_press: root.manager.current = 'new_workout'
        Button:
            text: 'Назад'
            size_hint_y: 0.1
            on_press: root.manager.current = 'menu'

<NewWorkoutScreen>:
    name: 'new_workout'
    BoxLayout:
        orientation: 'vertical'
        padding: 40
        spacing: 15
        Label:
            text: 'Новая тренировка'
            size_hint_y: 0.1
        TextInput:
            id: workout_desc
            hint_text: 'Описание тренировки'
            size_hint_y: 0.2
        BoxLayout:
            size_hint_y: 0.2
            spacing: 5
            TextInput:
                id: workout_date
                hint_text: 'Дата'
            Button:
                text: 'Сегодня'
                size_hint_x: 0.35
                on_press: root.set_today_date()
        TextInput:
            id: bodyweight
            hint_text: 'Вес тела (необязательно)'
            input_filter: 'float'
            size_hint_y: 0.2
        ScrollView:
            BoxLayout:
                id: selected_exercises
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 5
        Button:
            text: 'Добавить упражнение'
            size_hint_y: 0.2
            on_press: root.manager.current = 'exercise_picker'
        Button:
            id: submit_btn
            text: 'Создать'
            size_hint_y: 0.2
            on_press: root.create_workout(workout_date.text, bodyweight.text, workout_desc.text)
        Button:
            text: 'Назад'
            size_hint_y: 0.2
            on_press: root.manager.current = 'workouts'
        