ScreenManager:
    MenuScreen:
    EditorScreen:
    ExercisesScreen:
    WorkoutsScreen:
    NewWorkoutScreen:
    ExercisePickerScreen:

<MenuScreen>:
    name: 'menu'
    BoxLayout:
        orientation: 'vertical'
        padding: 40
        spacing: 15
        Label:
            text: 'Трекер тренировок'
        Button:
            text: 'Мои тренировки'
            on_press: root.manager.current='workouts'
        Button:
            text: 'Редактор'
            on_press: root.manager.current = 'editor'


<ExercisePickerScreen>:
    name: 'exercise_picker'
    BoxLayout:
        orientation: 'vertical'
        padding: 40
        spacing: 15
        Label:
            text: 'Выберите упражнение'
            size_hint_y: 0.1
        ScrollView:
            BoxLayout:
                id: picker_list
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 5
        Button:
            text: 'Назад'
            size_hint_y: 0.1
            on_press: root.manager.current = 'new_workout'

<EditorScreen>:
    name: 'editor'
    BoxLayout:
        orientation: 'vertical'
        padding: 40
        spacing: 15
        Label:
            text: 'Редактор'
            size_hint_y: 0.1
        Button:
            text: 'Упражнения'
            size_hint_y: 0.1
            on_press: root.manager.current = 'exercises'
        Widget: 
        Button:
            text: 'Назад'
            size_hint_y: 0.1
            on_press: root.manager.current = 'menu'

<ExercisesScreen>:
    name: 'exercises'
    BoxLayout:
        orientation: 'vertical'
        padding: 40
        spacing: 15
        Label:
            text: 'Упражнения'
            size_hint_y: 0.1
        TextInput:
            id: exercise_name
            hint_text: 'Название упражнения'
            size_hint_y: 0.1
        Button:
            text: 'Сохранить'
            size_hint_y: 0.1
            on_press: root.save_exercise(exercise_name.text)
        ScrollView:
            id: scroll
            BoxLayout:
                id: exercise_list
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 10
        Button:
            text: 'Назад'
            size_hint_y: 0.1
            on_press: root.manager.current = 'editor'


<WorkoutsScreen>:
    name: 'workouts'
    BoxLayout:
        orientation: 'vertical'
        padding: 40
        spacing: 15
        Label:
            text: 'Мои тренировки'
            size_hint_y: 0.1
        Button:
            text: 'Новая тренировка'
            size_hint_y: 0.1
            on_press: root.manager.current = 'new_workout'
        ScrollView:
            BoxLayout:
                id: workout_list
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 10
        Button:
            text: 'Назад'
            size_hint_y: 0.1
            on_press: root.manager.current = 'menu'

<NewWorkoutScreen>:
    name: 'new_workout'
    BoxLayout:
        orientation: 'vertical'
        padding: 40
        spacing: 15
        Label:
            text: 'Новая тренировка'
            size_hint_y: 0.1
        TextInput:
            id: workout_desc
            hint_text: 'Описание тренировки'
            size_hint_y: 0.2
        BoxLayout:
            size_hint_y: 0.2
            spacing: 5
            TextInput:
                id: workout_date
                hint_text: 'Дата'
            Button:
                text: 'Сегодня'
                size_hint_x: 0.35
                on_press: root.set_today_date()
        TextInput:
            id: bodyweight
            hint_text: 'Вес тела (необязательно)'
            input_filter: 'float'
            size_hint_y: 0.2
        Button:
            text: 'Добавить упражнение'
            size_hint_y: 0.2
            on_press: root.manager.current = 'exercise_picker'
        ScrollView:
            BoxLayout:
                id: selected_exercises
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 5
        Button:
            text: 'Создать'
            size_hint_y: 0.2
            on_press: root.create_workout(workout_date.text, bodyweight.text, workout_desc.text)
        Button:
            text: 'Назад'
            size_hint_y: 0.2
            on_press: root.manager.current = 'workouts'
        