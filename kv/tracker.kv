<Button>:
    background_normal: ''
    background_color: 0, 0, 0, 0
    color: 1, 1, 1, 1
    font_name: 'fonts/7.otf'
    canvas.before:
        Color:
            rgba: 1, 1, 1, 0.15
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [10]
        Color:
            rgba: 1, 1, 1, 0.6
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, 10
            width: 1.2
<TextInput>:
    background_normal: ''
    background_color: 0, 0, 0, 0
    foreground_color: 1, 1, 1, 1
    hint_text_color: 1, 1, 1, 0.8
    cursor_color: 1, 1, 1, 1
    padding: [10, 10, 10, 10]
    font_name: 'fonts/7.otf'
    halign: 'center'
    font_size: '17sp'
    canvas.before:
        Color:
            rgba: 1, 1, 1, 0.15
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [10]
        Color:
            rgba: 1, 1, 1, 0.6
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, 10
            width: 1.2
<SetTextInput>:
    background_normal: ''
    background_color: 0, 0, 0, 0.7
    foreground_color: 1, 1, 1, 1
    font_size: '21sp'
    halign: 'center'
    multiline: False
    padding: [0, (self.height - self.line_height) / 2, 0, (self.height - self.line_height) / 2]
<Label>:
    font_name: 'fonts/7.otf'
    font_size: '20sp'
    color: 1, 1, 1, 1
ScreenManager:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            source: 'Images/3.png'
            pos: self.pos
            size: self.size
    MenuScreen:
    ExercisesScreen:
    WorkoutsScreen:
    NewWorkoutScreen:
    ExercisePickerScreen:
    CopyWorkoutScreen:
    WorkoutDetailScreen:
    ExerciseDetailScreen:





<ExerciseDetailScreen>:
    name: 'exercise_detail'
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 15
        
        Label:
            id: exercise_title
            text: ''
            size_hint_y: 0.15
            font_size: '35sp'
            font_name: 'fonts/7.otf'
            bold: True
            
        ScrollView:
            BoxLayout:
                id: sets_list
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 10
                
        Button:
            text: 'Назад'
            size_hint_y: 0.1
            on_press: root.manager.current = 'workout_detail'

<WorkoutDetailScreen>:
    name: 'workout_detail'
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 15
        Label:
            text: 'Упражнения'
            font_name: 'fonts/2.otf'
            font_size: '26sp'
            size_hint_y: 0.1
        ScrollView:
            BoxLayout:
                id: detail_exercise_list
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 10
        Button:
            text: 'Назад'
            size_hint_y: 0.1
            on_press: root.manager.current = 'workouts'


<MenuScreen>:
    name: 'menu'
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 15
        Label:
            text: 'ТРЕКЕР ТРЕНИРОВОК'
            font_size: '30sp'
            font_name: 'fonts/2.otf'
        Button:
            text: 'Мои тренировки'
            on_press: root.manager.current='workouts'
            size_hint_y: 0.3
        Button:
            text: 'Редактор упражнений'
            on_press: root.manager.current = 'exercises'
            size_hint_y: 0.2



<ExercisePickerScreen>:
    name: 'exercise_picker'
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 15
        Label:
            text: 'Выберите упражнение'
            size_hint_y: 0.1
            font_size: '22sp'
            font_name: 'fonts/2.otf'
        BoxLayout:
            size_hint_y: 0.1
            spacing: 5
            TextInput:
                id: exercise_name
                hint_text: 'Новое упражнение'
            Button:
                text: '+'
                size_hint_x: 0.15
                on_press: root.save_exercise(exercise_name.text)
        ScrollView:
            BoxLayout:
                id: picker_list
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 5
        Button:
            text: 'Назад'
            size_hint_y: 0.1
            on_press: root.manager.current = 'new_workout'


<ExercisesScreen>:
    name: 'exercises'
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 15
        Label:
            text: 'Упражнения'
            size_hint_y: 0.1
            font_size: '25sp'
            font_name: 'fonts/2.otf'
        BoxLayout:
            size_hint_y: 0.1
            spacing: 5
            TextInput:
                id: exercise_name
                hint_text: 'Новое упражнение'
            Button:
                text: '+'
                size_hint_x: 0.15
                on_press: root.save_exercise(exercise_name.text)
        ScrollView:
            id: scroll
            BoxLayout:
                id: exercise_list
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 10
        Button:
            text: 'Назад'
            size_hint_y: 0.115
            on_press: root.manager.current = 'menu'


<WorkoutsScreen>:
    name: 'workouts'
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 15
        Label:
            text: 'Мои тренировки'
            size_hint_y: 0.1
            font_size: '27sp'
            font_name: 'fonts/2.otf'
        ScrollView:
            BoxLayout:
                id: workout_list
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 10
        Button:
            text: 'Новая тренировка'
            size_hint_y: 0.1
            on_press: root.manager.current = 'new_workout'
            
        Button:
            text: 'Назад'
            size_hint_y: 0.1
            on_press: root.manager.current = 'menu'

<NewWorkoutScreen>:
    name: 'new_workout'
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 15
        Label:
            text: 'Новая тренировка'
            size_hint_y: 0.1
            font_size: '25sp'
            font_name: 'fonts/2.otf'
        TextInput:
            id: workout_desc
            hint_text: 'Описание тренировки'
            size_hint_y: 0.2
        BoxLayout:
            size_hint_y: 0.15
            spacing: 5
            TextInput:
                id: bodyweight
                hint_text: 'Вес'
                input_filter: 'float'
                size_hint_x: 0.5
            TextInput:
                id: workout_date
                hint_text: 'Дата'
            Button:
                text: 'Сегодня'
                size_hint_x: 0.45
                on_press: root.set_today_date()
                font_size: '15sp'
        ScrollView:
            BoxLayout:
                id: selected_exercises
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 5
        Button:
            text: 'Добавить упражнение'
            size_hint_y: 0.15
            on_press: root.manager.current = 'exercise_picker'
        Button:
            text: 'Скопировать существующую'
            size_hint_y: 0.15
            on_press: root.manager.current = 'copy_workout'
        Button:
            id: submit_btn
            text: 'Создать'
            size_hint_y: 0.15
            on_press: root.create_workout(workout_date.text, bodyweight.text, workout_desc.text)
        Button:
            text: 'Назад'
            size_hint_y: 0.15
            on_press: root.manager.current = 'workouts'

<CopyWorkoutScreen>:
    name: 'copy_workout'
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 15
        Label:
            text: 'Выберите тренировку'
            size_hint_y: 0.1
        ScrollView:
            BoxLayout:
                id: copy_list
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 10
        Button:
            text: 'Назад'
            size_hint_y: 0.1
            on_press: root.manager.current = 'new_workout'